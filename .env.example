# ── OpenAI ────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
EMBEDDING_MODEL=text-embedding-3-small
LLM_MODEL=gpt-4o

# ── Chroma ────────────────────────────────────────────────
CHROMA_PERSIST_DIR=./chroma_store
CHROMA_COLLECTION=github_profiles

# ── Data ──────────────────────────────────────────────────
DATA_DIR=./data

# ── API ───────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000

# ── LangSmith Tracing (optional) ─────────────────────────
# Set LANGSMITH_TRACING=true to enable
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=github-profile-intelligence
LANGSMITH_ENDPOINT=https://api.smith.langchain.com

# ── DeepEval (optional) ───────────────────────────────────
# Responses are saved to ./eval_logs/ when SAVE_RESPONSES=true
SAVE_RESPONSES=false
EVAL_LOG_DIR=./eval_logs
